{
  "name": "koenvangilst.nl",
  "version": "9.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "start": "srvx --entry dist/server/server.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:docker": "node scripts/run-e2e-docker.mjs",
    "type-check": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "knip": "knip",
    "update-deps": "node scripts/update-deps.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mdx-js/react": "3.1.1",
    "@mdx-js/rollup": "3.1.1",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "d3": "7.9.0",
    "d3-hexbin": "0.2.2",
    "echarts": "6.1.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-autolink-headings": "7.1.0",
    "rehype-code-titles": "1.2.1",
    "rehype-prism-plus": "2.0.2",
    "rehype-slug": "6.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx-frontmatter": "5.2.0",
    "tailwindcss": "4.3.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-router-devtools": "1.167.0",
    "@types/d3": "7.4.3",
    "@types/d3-hexbin": "0.2.5",
    "@types/mdast": "4.0.4",
    "@types/mdx": "2.0.14",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.5.0",
    "husky": "9.1.7",
    "knip": "6.17.1",
    "lint-staged": "17.0.7",
    "playwright": "1.61.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "unist-util-visit": "5.1.0",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
